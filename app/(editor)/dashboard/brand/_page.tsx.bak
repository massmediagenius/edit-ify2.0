"use client";

import { useEffect, useState } from "react";
import { Play, X, Check, Palette, Type, Zap } from "lucide-react";
import { cn } from "@/lib/utils";

const COLORS = [
  { name: "Cyan", hex: "#00E5FF", label: "accent-cyan" },
  { name: "Purple", hex: "#A855F7", label: "accent-purple" },
  { name: "Green", hex: "#22C55E", label: "accent-green" },
  { name: "Orange", hex: "#F97316", label: "accent-orange" },
  { name: "Surface", hex: "#1A1D24", label: "surface" },
  { name: "Background", hex: "#0F1115", label: "background" },
];

const RULES = [
  { icon: Zap, title: "Motion First", desc: "Every clip must have intentional motion — static frames read as amateur." },
  { icon: Palette, title: "Color Match", desc: "Color grade must align with the brand palette. No warm tones unless explicitly in the brief." },
  { icon: Type, title: "Typography Hierarchy", desc: "One primary font per edit. No more than two weights. Never use default system fonts." },
];

const NEVER_ACCEPT = [
  "Blurry or out-of-focus footage submitted as final",
  "Watermarks from any software (CapCut, DaVinci, etc.)",
  "Mismatched audio — lip sync issues on talking head clips",
  "Unmasked logos or faces that should be hidden per brief",
  "Exported under 1080p resolution",
  "Missing end card or incorrect branding placement",
];

export default function BrandPage() {
  const [showButton, setShowButton] = useState(false);

  useEffect(() => {
    function handleScroll() {
      setShowButton(window.scrollY > 200);
    }
    window.addEventListener("scroll", handleScroll);
    return () => window.removeEventListener("scroll", handleScroll);
  }, []);

  return (
    <div className="max-w-3xl mx-auto pb-24">
      {/* Hero */}
      <div className="mb-10">
        <h1 className="font-heading text-4xl font-extrabold mb-3 bg-gradient-to-r from-accent-purple to-accent-cyan bg-clip-text text-transparent">
          The Edify Standard
        </h1>
        <p className="text-text-secondary text-base leading-relaxed">
          Every edit you make represents the brand. Read this before you submit anything.
        </p>
      </div>

      {/* Section 1 */}
      <section className="mb-10">
        <h2 className="font-heading text-xl font-bold text-text-primary mb-4 pl-4 border-l-2 border-accent-cyan">
          The Energy We Chase
        </h2>
        <p className="text-text-secondary text-sm leading-relaxed mb-4">
          We don&apos;t make content that blends in. Every frame should provoke a reaction — whether that&apos;s adrenaline, relatability, or aspiration. Safe edits don&apos;t build followings.
        </p>
        <blockquote className="bg-surface-raised border-l-4 border-accent-cyan rounded-r-xl px-5 py-4 italic text-text-primary text-sm">
          &ldquo;Never basic. Every frame should feel intentional.&rdquo;
        </blockquote>
      </section>

      {/* Section 2 */}
      <section className="mb-10">
        <h2 className="font-heading text-xl font-bold text-text-primary mb-4 pl-4 border-l-2 border-accent-cyan">
          Content Style Rules
        </h2>
        <div className="grid grid-cols-3 gap-4">
          {RULES.map(({ icon: Icon, title, desc }) => (
            <div key={title} className="bg-surface border border-border rounded-xl p-4">
              <div className="w-8 h-8 rounded-lg bg-accent-cyan/10 flex items-center justify-center mb-3">
                <Icon className="w-4 h-4 text-accent-cyan" />
              </div>
              <div className="font-heading font-bold text-text-primary text-sm mb-1">{title}</div>
              <p className="text-text-muted text-xs leading-relaxed">{desc}</p>
            </div>
          ))}
        </div>
      </section>

      {/* Section 3 */}
      <section className="mb-10">
        <h2 className="font-heading text-xl font-bold text-text-primary mb-4 pl-4 border-l-2 border-accent-cyan">
          Color & Typography
        </h2>
        <div className="grid grid-cols-3 gap-3">
          {COLORS.map(({ name, hex, label }) => (
            <div key={hex} className="rounded-xl overflow-hidden border border-border">
              <div className="h-16" style={{ backgroundColor: hex }} />
              <div className="bg-surface-raised px-3 py-2">
                <div className="text-xs font-bold text-text-primary">{name}</div>
                <div className="text-[10px] text-text-muted font-mono">{hex}</div>
                <div className="text-[10px] text-text-muted">{label}</div>
              </div>
            </div>
          ))}
        </div>
      </section>

      {/* Section 4 */}
      <section className="mb-10">
        <h2 className="font-heading text-xl font-bold text-text-primary mb-4 pl-4 border-l-2 border-accent-cyan">
          Example Edit Standards
        </h2>
        <div className="grid grid-cols-2 gap-4">
          {["Hype Category", "Podcast Category"].map((label, i) => (
            <div key={i} className="bg-surface-raised border border-border rounded-xl overflow-hidden">
              <div className="h-36 bg-background flex items-center justify-center relative">
                <div className="w-12 h-12 rounded-full bg-white/10 flex items-center justify-center">
                  <Play className="w-5 h-5 text-white ml-0.5" />
                </div>
                <span className="absolute top-2 left-2 text-xs font-bold text-white/50">EXAMPLE</span>
              </div>
              <div className="px-4 py-3">
                <p className="text-sm text-text-secondary">
                  Example Edit #{i + 1} — {label}
                </p>
              </div>
            </div>
          ))}
        </div>
      </section>

      {/* Section 5 */}
      <section className="mb-10">
        <h2 className="font-heading text-xl font-bold text-text-primary mb-4 pl-4 border-l-2 border-accent-orange">
          What We Never Accept
        </h2>
        <div className="flex flex-col gap-2">
          {NEVER_ACCEPT.map((item) => (
            <div key={item} className="flex items-start gap-3 bg-accent-orange/5 border border-accent-orange/20 rounded-xl px-4 py-3">
              <X className="w-4 h-4 text-accent-orange mt-0.5 shrink-0" />
              <p className="text-sm text-text-secondary">{item}</p>
            </div>
          ))}
        </div>
      </section>

      {/* Floating CTA */}
      <div
        className={cn(
          "fixed bottom-6 right-6 transition-all duration-300",
          showButton ? "opacity-100 translate-y-0" : "opacity-0 translate-y-4 pointer-events-none"
        )}
      >
        <button className="flex items-center gap-2 bg-accent-cyan text-background px-5 py-3 rounded-xl font-semibold text-sm shadow-glow-cyan hover:bg-accent-cyan/90 transition-colors">
          <Check className="w-4 h-4" />
          You&apos;ve read the guidelines
        </button>
      </div>
    </div>
  );
}
