"use client";

import { useState } from "react";
import { Folder, FolderOpen, ChevronRight, Download, Search } from "lucide-react";
import { GlowCard } from "@/components/ui/GlowCard";
import { cn } from "@/lib/utils";

type FolderNode = { id: string; name: string; children?: FolderNode[] };

const TREE: FolderNode[] = [
  {
    id: "alpha",
    name: "Project Alpha",
    children: [
      { id: "alpha-raw", name: "Raw Footage" },
      { id: "alpha-audio", name: "Audio Stems" },
      { id: "alpha-gfx", name: "Graphics" },
    ],
  },
  {
    id: "beta",
    name: "Project Beta",
    children: [
      { id: "beta-int", name: "Interviews" },
      { id: "beta-broll", name: "B-Roll" },
    ],
  },
  { id: "sfx", name: "Sound Effects" },
  { id: "transitions", name: "Transitions Pack" },
];

const MOCK_FILES: Record<string, { name: string; type: string; size: string; gradient: string }[]> = {
  "alpha-raw": [
    { name: "scene_01_wide.mp4", type: "MP4", size: "1.2 GB", gradient: "from-orange-600 to-amber-500" },
    { name: "scene_02_close.mp4", type: "MP4", size: "890 MB", gradient: "from-blue-600 to-indigo-500" },
    { name: "bts_footage_a.mp4", type: "MP4", size: "450 MB", gradient: "from-teal-600 to-cyan-500" },
    { name: "aerial_shot.mp4", type: "MP4", size: "2.1 GB", gradient: "from-purple-600 to-pink-500" },
    { name: "interview_raw.mp4", type: "MP4", size: "780 MB", gradient: "from-red-600 to-orange-500" },
    { name: "b_roll_streets.mp4", type: "MP4", size: "320 MB", gradient: "from-green-600 to-teal-500" },
  ],
  "alpha-audio": [
    { name: "main_track_stems.wav", type: "WAV", size: "240 MB", gradient: "from-violet-600 to-purple-500" },
    { name: "ambient_bg.wav", type: "WAV", size: "48 MB", gradient: "from-indigo-600 to-blue-500" },
    { name: "sfx_pack_01.zip", type: "ZIP", size: "120 MB", gradient: "from-slate-600 to-gray-500" },
  ],
  "alpha-gfx": [
    { name: "lower_third_01.png", type: "PNG", size: "2.4 MB", gradient: "from-cyan-600 to-blue-500" },
    { name: "logo_overlay.png", type: "PNG", size: "800 KB", gradient: "from-emerald-600 to-green-500" },
    { name: "end_card.png", type: "PNG", size: "1.1 MB", gradient: "from-yellow-600 to-orange-500" },
    { name: "thumbnail_template.psd", type: "PSD", size: "45 MB", gradient: "from-rose-600 to-pink-500" },
  ],
};

const TYPE_COLORS: Record<string, string> = {
  MP4: "bg-accent-cyan/15 text-accent-cyan",
  WAV: "bg-accent-purple/15 text-accent-purple",
  PNG: "bg-accent-green/15 text-accent-green",
  ZIP: "bg-accent-yellow/15 text-accent-yellow",
  PSD: "bg-accent-orange/15 text-accent-orange",
};

function FolderItem({
  node,
  depth = 0,
  activeId,
  expanded,
  onToggle,
  onSelect,
}: {
  node: FolderNode;
  depth?: number;
  activeId: string | null;
  expanded: Set<string>;
  onToggle: (id: string) => void;
  onSelect: (id: string) => void;
}) {
  const isExpanded = expanded.has(node.id);
  const hasChildren = node.children && node.children.length > 0;
  const isActive = activeId === node.id;

  return (
    <div>
      <button
        onClick={() => {
          if (hasChildren) onToggle(node.id);
          onSelect(node.id);
        }}
        className={cn(
          "w-full flex items-center gap-2 py-2 px-2 rounded-lg text-left text-sm transition-all duration-150",
          isActive ? "bg-surface-raised border-l-2 border-accent-cyan text-text-primary pl-[6px]" : "hover:bg-surface-raised text-text-secondary border-l-2 border-transparent",
        )}
        style={{ paddingLeft: depth * 12 + (isActive ? 6 : 8) + "px" }}
      >
        {hasChildren ? (
          <ChevronRight className={cn("w-3.5 h-3.5 shrink-0 transition-transform", isExpanded && "rotate-90")} />
        ) : (
          <span className="w-3.5" />
        )}
        {isActive ? (
          <FolderOpen className="w-4 h-4 shrink-0 text-accent-cyan" />
        ) : (
          <Folder className="w-4 h-4 shrink-0 text-accent-cyan/70" />
        )}
        <span className="truncate">{node.name}</span>
      </button>
      {hasChildren && isExpanded && (
        <div>
          {node.children!.map((child) => (
            <FolderItem
              key={child.id}
              node={child}
              depth={depth + 1}
              activeId={activeId}
              expanded={expanded}
              onToggle={onToggle}
              onSelect={onSelect}
            />
          ))}
        </div>
      )}
    </div>
  );
}

function getBreadcrumb(tree: FolderNode[], targetId: string, path: string[] = []): string[] | null {
  for (const node of tree) {
    const newPath = [...path, node.name];
    if (node.id === targetId) return newPath;
    if (node.children) {
      const found = getBreadcrumb(node.children, targetId, newPath);
      if (found) return found;
    }
  }
  return null;
}

export default function AssetsPage() {
  const [activeFolder, setActiveFolder] = useState<string | null>(null);
  const [expanded, setExpanded] = useState<Set<string>>(new Set(["alpha"]));
  const [search, setSearch] = useState("");

  function toggleExpand(id: string) {
    setExpanded((prev) => {
      const next = new Set(prev);
      if (next.has(id)) next.delete(id);
      else next.add(id);
      return next;
    });
  }

  const files = activeFolder ? (MOCK_FILES[activeFolder] ?? []) : [];
  const filteredFiles = files.filter((f) => f.name.toLowerCase().includes(search.toLowerCase()));
  const breadcrumb = activeFolder ? getBreadcrumb(TREE, activeFolder) : null;

  return (
    <div className="flex h-[calc(100vh-56px-48px)] -m-6 overflow-hidden">
      {/* Left panel */}
      <aside className="w-[280px] shrink-0 bg-surface border-r border-border p-4 flex flex-col gap-3 overflow-y-auto">
        <h2 className="font-heading font-bold text-text-primary text-sm">Asset Library</h2>
        <div className="relative">
          <Search className="absolute left-2.5 top-1/2 -translate-y-1/2 w-3.5 h-3.5 text-text-muted" />
          <input
            value={search}
            onChange={(e) => setSearch(e.target.value)}
            placeholder="Search assets..."
            className="w-full bg-surface-raised border border-border rounded-lg pl-8 pr-3 py-2 text-xs text-text-primary placeholder:text-text-muted focus:outline-none focus:border-accent-cyan transition-colors"
          />
        </div>
        <div className="flex flex-col gap-0.5">
          {TREE.map((node) => (
            <FolderItem
              key={node.id}
              node={node}
              activeId={activeFolder}
              expanded={expanded}
              onToggle={toggleExpand}
              onSelect={setActiveFolder}
            />
          ))}
        </div>
      </aside>

      {/* Right panel */}
      <div className="flex-1 p-6 overflow-y-auto">
        {!activeFolder ? (
          <div className="h-full flex flex-col items-center justify-center gap-3 text-text-muted">
            <FolderOpen className="w-12 h-12 opacity-30" />
            <p className="text-sm">Select a folder to view assets</p>
          </div>
        ) : (
          <>
            {/* Breadcrumb */}
            <div className="flex items-center gap-1.5 text-xs text-text-muted mb-5">
              <span>Assets</span>
              {breadcrumb?.map((crumb, i) => (
                <span key={i} className="flex items-center gap-1.5">
                  <ChevronRight className="w-3 h-3" />
                  <span className={i === breadcrumb.length - 1 ? "text-text-secondary" : ""}>{crumb}</span>
                </span>
              ))}
            </div>

            {filteredFiles.length === 0 ? (
              <div className="text-center text-text-muted py-16 text-sm">No files in this folder</div>
            ) : (
              <div className="grid grid-cols-4 gap-4">
                {filteredFiles.map((file) => (
                  <GlowCard key={file.name} className="overflow-hidden">
                    <div className={cn("w-full h-28 bg-gradient-to-br", file.gradient)} />
                    <div className="p-3">
                      <p className="text-xs font-medium text-text-primary truncate" title={file.name}>
                        {file.name}
                      </p>
                      <div className="flex items-center justify-between mt-1.5 mb-3">
                        <span className={cn("text-[10px] font-bold px-1.5 py-0.5 rounded-full", TYPE_COLORS[file.type] ?? "bg-surface text-text-muted")}>
                          {file.type}
                        </span>
                        <span className="text-[10px] text-text-muted">{file.size}</span>
                      </div>
                      <button className="w-full flex items-center justify-center gap-1.5 py-1.5 rounded-lg border border-accent-cyan/40 text-accent-cyan text-xs font-medium hover:bg-accent-cyan/10 transition-colors">
                        <Download className="w-3 h-3" /> Download
                      </button>
                    </div>
                  </GlowCard>
                ))}
              </div>
            )}
          </>
        )}
      </div>
    </div>
  );
}
